Vacuum Cleaner Problem
# Vacuum Cleaner Problem

# Environment
rooms = {
    'A': 'Dirty',
    'B': 'Dirty'
}

# Vacuum starts in Room A
location = 'A'

print("Initial Room Status:")
print(rooms)
print()

while True:

    if rooms[location] == "Dirty":
        print("Vacuum is in Room", location)
        print("Room", location, "is Dirty.")
        print("Action: SUCK\n")
        rooms[location] = "Clean"

    else:
        print("Vacuum is in Room", location)
        print("Room", location, "is already Clean.\n")

    # Check if both rooms are clean
    if rooms['A'] == "Clean" and rooms['B'] == "Clean":
        print("All rooms are clean.")
        break

    # Move to the other room
    if location == 'A':
        print("Moving from Room A to Room B...\n")
        location = 'B'
    else:
        print("Moving from Room B to Room A...\n")
        location = 'A'

print("\nFinal Room Status:")
print(rooms)
