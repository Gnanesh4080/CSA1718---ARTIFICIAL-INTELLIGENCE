8-Puzzle Problem Using A* Search Algorithm
import heapq
import copy

GOAL_STATE = [
    [1, 2, 3],
    [4, 5, 6],
    [7, 8, 0]
]

MOVES = [
    (-1, 0),
    (1, 0),
    (0, -1),
    (0, 1)
]

class PuzzleNode:

    def __init__(self, state, parent=None, move=None, g=0):

        self.state = state
        self.parent = parent
        self.move = move
        self.g = g
        self.h = self.calculate_heuristic()
        self.f = self.g + self.h

    def calculate_heuristic(self):

        distance = 0

        for i in range(3):
            for j in range(3):

                value = self.state[i][j]

                if value != 0:

                    goal_x = (value - 1) // 3
                    goal_y = (value - 1) % 3

                    distance += abs(goal_x - i) + abs(goal_y - j)

        return distance

    def __lt__(self, other):

        return self.f < other.f


def print_state(state):

    for row in state:
        print(row)

    print()


def find_blank(state):

    for i in range(3):
        for j in range(3):
            if state[i][j] == 0:
                return i, j


def generate_children(node):

    children = []

    x, y = find_blank(node.state)

    for dx, dy in MOVES:

        new_x = x + dx
        new_y = y + dy

        if 0 <= new_x < 3 and 0 <= new_y < 3:

            new_state = copy.deepcopy(node.state)

            new_state[x][y], new_state[new_x][new_y] = \
                new_state[new_x][new_y], new_state[x][y]

            child = PuzzleNode(
                new_state,
                parent=node,
                move=(new_x, new_y),
                g=node.g + 1
            )

            children.append(child)

    return children


def state_to_tuple(state):

    return tuple(tuple(row) for row in state)


def reconstruct_path(node):

    path = []

    while node:

        path.append(node)

        node = node.parent

    path.reverse()

    return path


def a_star(start_state):

    open_list = []

    visited = set()

    start_node = PuzzleNode(start_state)

    heapq.heappush(open_list, start_node)

    while open_list:

        current = heapq.heappop(open_list)

        if current.state == GOAL_STATE:

            return reconstruct_path(current)

        visited.add(state_to_tuple(current.state))

        children = generate_children(current)

        for child in children:

            if state_to_tuple(child.state) not in visited:

                heapq.heappush(open_list, child)

    return None


def main():

    start = [
        [1, 2, 3],
        [4, 0, 6],
        [7, 5, 8]
    ]

    print("Initial State\n")
    print_state(start)

    solution = a_star(start)

    if solution:

        print("Solution Found\n")

        for step, node in enumerate(solution):

            print("Step:", step)

            print_state(node.state)

        print("Total Moves =", len(solution) - 1)

    else:

        print("No Solution Exists")


if __name__ == "__main__":
    main()
